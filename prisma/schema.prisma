generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentRunStatus {
  running
  success
  failed
}

model Agent {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  description String?
  tools     Json
  mode      String
  createdAt DateTime @default(now())
}

model AgentRun {
  id        String   @id @default(uuid()) @db.Uuid
  agentId   String
  task      String
  status    AgentRunStatus @default(running)
  result    String
  logs      Json
  createdAt DateTime @default(now())
}
